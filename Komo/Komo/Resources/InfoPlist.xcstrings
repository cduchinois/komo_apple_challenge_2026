        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo legge il tuo calendario per comprendere il tuo carico giornaliero e suggerire finestre di recupero migliori."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo はカレンダーを読み取り、毎日の負荷を理解し、より良い回復期間を提案します。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo lê seu calendário para entender sua carga diária e sugerir melhores janelas de recuperação."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo 读取您的日历以了解您的每日负荷并建议更好的恢复窗口。"
          }
        }
      }
    },
    "NSHealthShareUsageDescription" : {
      "comment" : "HealthKit read permission",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo benötigt Zugriff auf Ihre Gesundheitsdaten, um Ihren Schlaf, Ihre Bewegung, Ihren Stress und Ihre Erholung zu verstehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo needs access to your health data to understand your sleep, movement, stress, and recovery."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo needs access to your health data to understand your sleep, movement, stress, and recovery."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo needs access to your health data to understand your sleep, movement, stress, and recovery."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo necesita acceso a sus datos de salud para comprender su sueño, movimiento, estrés y recuperación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo a besoin d'accéder à tes données Santé pour comprendre ton sommeil, ton mouvement, ton stress et ta récupération."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo ha bisogno di accedere ai tuoi dati sanitari per comprendere il tuo sonno, il movimento, lo stress e il recupero."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo は、あなたの睡眠、動き、ストレス、回復を理解するためにあなたの健康データにアクセスする必要があります。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo precisa de acesso aos seus dados de saúde para compreender seu sono, movimento, estresse e recuperação."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo 需要访问您的健康数据以了解您的睡眠、运动、压力和恢复情况。"
          }
        }
      }
    },
