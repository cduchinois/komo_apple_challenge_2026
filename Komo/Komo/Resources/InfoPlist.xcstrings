    "NSCalendarsFullAccessUsageDescription" : {
      "comment" : "Calendar full access permission",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo benötigt vollen Zugriff auf Ihren Kalender, um Ihre Besprechungen zu zählen und Ihre kognitive Belastung zu verstehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo needs full access to your calendar to count your meetings and understand your cognitive load."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo needs full access to your calendar to count your meetings and understand your cognitive load."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo needs full access to your calendar to count your meetings and understand your cognitive load."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo necesita acceso completo a su calendario para contar sus reuniones y comprender su carga cognitiva."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo a besoin d'un accès complet à ton calendrier pour compter tes réunions et comprendre ta charge cognitive."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo ha bisogno dell'accesso completo al tuo calendario per contare le tue riunioni e comprendere il tuo carico cognitivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo は、会​​議をカウントし、認知負荷を理解するために、カレンダーに完全にアクセスする必要があります。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo precisa de acesso total à sua agenda para contar suas reuniões e entender sua carga cognitiva."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo 需要完全访问您的日历来计算您的会议并了解您的认知负荷。"
          }
        }
      }
    },
    "NSCalendarsUsageDescription" : {
      "comment" : "Calendar read permission",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo liest Ihren Kalender, um Ihre tägliche Belastung zu verstehen und bessere Erholungsfenster vorzuschlagen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo reads your calendar to understand your daily load and suggest better recovery windows."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo reads your calendar to understand your daily load and suggest better recovery windows."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo reads your calendar to understand your daily load and suggest better recovery windows."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo lee su calendario para comprender su carga diaria y sugerir mejores ventanas de recuperación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komo lit ton calendrier pour comprendre ta charge quotidienne et suggérer de meilleures fenêtres de récupération."
