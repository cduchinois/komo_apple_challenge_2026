    "komo can use health data to understand your sleep, movement, stress, and recovery.": {
      "comment": "Onboarding UI",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "komo peut utiliser tes données santé pour comprendre ton sommeil, ton mouvement, ton stress et ta récupération."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "komo can use health data to understand your sleep, movement, stress, and recovery."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "komo puede utilizar datos de salud para comprender su sueño, movimiento, estrés y recuperación."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "komo kann Gesundheitsdaten verwenden, um Ihren Schlaf, Ihre Bewegung, Ihren Stress und Ihre Erholung zu verstehen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "komo pode usar dados de saúde para compreender seu sono, movimento, estresse e recuperação."
          }
