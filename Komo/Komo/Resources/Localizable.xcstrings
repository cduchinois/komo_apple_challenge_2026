    "mornings go better when you begin with focus instead of scrolling.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "les matins vont mieux quand tu commences par te concentrer plutôt que scroller."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "mornings go better when you begin with focus instead of scrolling."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las mañanas van mejor cuando empiezas concentrándote en lugar de desplazarte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Morgen verläuft besser, wenn Sie mit der Konzentration beginnen, anstatt zu scrollen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "as manhãs ficam melhores quando você começa com o foco em vez de rolar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スクロールするのではなく集中して始めると、朝の気分が良くなります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当你从专注而不是滚动开始时，早晨会过得更好。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "le mattine vanno meglio quando inizi a concentrarti invece che a scorrere."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "mornings go better when you begin with focus instead of scrolling."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "mornings go better when you begin with focus instead of scrolling."
          }
        }
      }
    },
