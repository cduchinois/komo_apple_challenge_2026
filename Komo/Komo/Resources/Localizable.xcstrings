          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "dim your phone at 9 tonight and see how your sleep feels."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "dim your phone at 9 tonight and see how your sleep feels."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "dim your phone at 9 tonight and see how your sleep feels."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atenúa tu teléfono a las 9 de la noche y observa cómo se siente tu sueño."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "baisse la luminosité à 21 h ce soir et vois comment tu dors."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "abbassa il telefono alle 9 stasera e vedi come ti senti a dormire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
