    "Low stress all day. That's rare — notice how it feels." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den ganzen Tag wenig Stress. Das kommt selten vor – achten Sie darauf, wie es sich anfühlt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Low stress all day. That's rare — notice how it feels."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Low stress all day. That's rare — notice how it feels."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Low stress all day. That's rare — notice how it feels."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bajo estrés todo el día. Eso es raro; observe cómo se siente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stress bas toute la journée. C'est rare — remarque ce que ça fait."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basso stress per tutto il giorno. È raro: nota come ci si sente."
