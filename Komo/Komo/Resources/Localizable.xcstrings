    "only %1$@ hours of sleep last night. that's less than your body needs.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "seulement %1$@ heures de sommeil cette nuit. c'est moins que ce dont ton corps a besoin."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "only %1$@ hours of sleep last night. that's less than your body needs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "solo %1$@ horas de sueño anoche. eso es menos de lo que tu cuerpo necesita."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Letzte Nacht habe ich nur %1$@ Stunden geschlafen. Das ist weniger, als Ihr Körper braucht."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "apenas %1$@ horas de sono na noite passada. isso é menos do que seu corpo precisa."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "昨夜の睡眠時間はわずか%1$@時間です。それは体が必要とする量よりも少ないのです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "昨晚只睡了 %1$@ 小时。这低于您的身体需求。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ho dormito solo %1$@ ore la notte scorsa. è meno di quello di cui il tuo corpo ha bisogno."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "only %1$@ hours of sleep last night. that's less than your body needs."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "only %1$@ hours of sleep last night. that's less than your body needs."
          }
        }
      }
    },
    "Only %1$@ hours of sleep. A short nap this afternoon could help.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seulement %1$@ heures de sommeil. Une courte sieste cet après-midi pourrait aider."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only %1$@ hours of sleep. A short nap this afternoon could help."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sólo %1$@ horas de sueño. Una pequeña siesta esta tarde podría ayudar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur %1$@ Stunden Schlaf. Ein kurzes Nickerchen heute Nachmittag könnte helfen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas %1$@ horas de sono. Uma soneca esta tarde pode ajudar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠時間はわずか%1$@時間です。今日の午後に短い昼寝をすると効果があるかもしれません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅 %1$@ 小时睡眠。今天下午小睡一会儿可能会有所帮助。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo %1$@ ore di sonno. Un breve pisolino questo pomeriggio potrebbe aiutare."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Only %1$@ hours of sleep. A short nap this afternoon could help."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Only %1$@ hours of sleep. A short nap this afternoon could help."
          }
        }
      }
    },
