    "a 10-minute walk right now would reset your body and your focus.": {
      "extractionState": "stale",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "une marche de 10 minutes maintenant remettrait ton corps et ta concentration."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
